# .env.example
# Copy this to a real .env file in your project root.
# .env must be in .gitignore — never commit it.

# --- generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=paste_generated_hex_here

# --- generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=paste_generated_fernet_key_here

# --- Phase 1: sqlite (default, no setup needed). Switch this line when you move to Postgres later:
# DATABASE_URL=postgresql://hr_user:yourpassword@localhost:5432/hr_agent
DATABASE_URL=sqlite:///./hr_agent.db
